{
	"appId": "com.rsh.myeasylist",
	"appName": "My Easy List",
	"webDir": "dist",
	"bundledWebRuntime": false,
	"plugins": {
		"FirebaseAuthentication": {
			"skipNativeAuth": true,
			"providers": [
				"google.com",
				"apple.com"
			]
		}
	},
	"packageClassList": [
		"FirebaseAuthenticationPlugin",
		"AppPlugin",
		"CAPBrowserPlugin",
		"SharePlugin",
		"SpeechRecognitionPlugin"
	]
}
